{
  "worker_id": "analyst_01",
  "workflow_id": "news_translation_to_markdown",
  "role": "analyst",
  "model": "claude-haiku-4-5",
  "entrypoint": "scan_and_analyze",
  "execution_config": {
    "timeout_seconds": 300,
    "max_retries": 3,
    "retry_delay_seconds": 5,
    "parallel": false
  },
  "task_config": {
    "task_name": "scan_and_analyze",
    "description": "Scan source file, extract metadata, identify entities, build terminology table",
    "steps": [
      {
        "step": 1,
        "name": "validate_and_read_file",
        "description": "Validate source file path and read content"
      },
      {
        "step": 2,
        "name": "extract_entities",
        "description": "Extract people, places, organizations, brands, and specialized terms"
      },
      {
        "step": 3,
        "name": "analyze_structure",
        "description": "Analyze article structure: titles, sections, paragraphs"
      },
      {
        "step": 4,
        "name": "build_terminology_table",
        "description": "Create terminology lookup table for translator"
      },
      {
        "step": 5,
        "name": "generate_analysis",
        "description": "Output file_analysis.json and terminology.json"
      }
    ]
  },
  "input_schema": {
    "source_file_path": {
      "type": "string",
      "description": "Absolute path to English news article",
      "required": true
    },
    "file_type": {
      "type": "string",
      "enum": ["txt", "md", "html", "pdf", "docx"],
      "description": "Source file format",
      "default": "txt"
    }
  },
  "output_schema": {
    "file_analysis": {
      "type": "object",
      "description": "Extracted file metadata and analysis"
    },
    "terminology_table": {
      "type": "object",
      "description": "Entity-to-translation mapping for consistency"
    }
  },
  "quality_settings": {
    "entity_extraction_confidence_threshold": 0.85,
    "include_technical_terms": true,
    "terminology_coverage_target": 0.95
  },
  "error_handling": {
    "on_file_not_found": "escalate_to_debug",
    "on_encoding_error": "auto_detect_and_retry",
    "on_timeout": "escalate_to_debug"
  },
  "optimization": {
    "goal": "speed",
    "prefer_conciseness": true,
    "skip_detailed_analysis": true
  },
  "output_format": {
    "file_analysis": "JSON",
    "terminology_table": "JSON",
    "encoding": "utf-8"
  },
  "dependencies": [],
  "provides": [
    "file_analysis",
    "terminology_table"
  ]
}
