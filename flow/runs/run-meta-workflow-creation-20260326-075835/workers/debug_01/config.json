{
  "worker_id": "debug_01",
  "workflow_id": "news_translation_to_markdown",
  "role": "debug",
  "model": "claude-sonnet-4-6",
  "entrypoint": "debug",
  "execution_config": {
    "timeout_seconds": 300,
    "max_retries": 1,
    "retry_delay_seconds": 5,
    "parallel": false
  },
  "task_config": {
    "task_name": "debug",
    "description": "Handle failures and errors in translation workflow",
    "steps": [
      {
        "step": 1,
        "name": "analyze_failure",
        "description": "Analyze the error and root cause"
      },
      {
        "step": 2,
        "name": "attempt_recovery",
        "description": "Attempt automatic recovery if possible"
      },
      {
        "step": 3,
        "name": "generate_report",
        "description": "Generate detailed error report"
      },
      {
        "step": 4,
        "name": "determine_action",
        "description": "Decide retry, escalate, or abort"
      }
    ]
  },
  "debug_settings": {
    "log_level": "debug",
    "include_context": true,
    "include_stack_trace": true,
    "max_analysis_depth": 3
  },
  "recovery_strategies": {
    "file_not_found": {
      "action": "report_and_abort",
      "message": "Source file path invalid or inaccessible"
    },
    "encoding_error": {
      "action": "attempt_fix",
      "strategies": ["auto_detect_encoding", "fallback_to_utf8"]
    },
    "terminology_mismatch": {
      "action": "attempt_fix",
      "strategies": ["use_best_judgment", "mark_for_review"]
    },
    "format_error": {
      "action": "attempt_fix",
      "strategies": ["auto_correct_markdown", "regenerate_from_source"]
    },
    "timeout": {
      "action": "retry_with_smaller_chunk",
      "max_attempts": 2
    }
  },
  "error_handling": {
    "recoverable_errors": [
      "encoding_error",
      "format_error",
      "terminology_mismatch",
      "timeout"
    ],
    "fatal_errors": [
      "file_not_found",
      "invalid_input_schema",
      "model_unavailable"
    ]
  },
  "escalation_policy": {
    "escalate_to_human": false,
    "max_auto_recovery_attempts": 2,
    "abort_on_fatal_error": true
  },
  "output_format": {
    "error_report": "JSON",
    "recovery_log": "JSON"
  }
}
