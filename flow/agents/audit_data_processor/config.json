    "Reconcile trial balance with GL",
    "Identify data anomalies and inconsistencies",
    "Prepare standardized data formats for testing"
  ],
  "authority_level": "medium",
  "version": "1.0.0",
  "created_at": "2026-03-27T06:35:00Z",
  "responsible_for_steps": [
    "step_01_collect_gl_data",
    "step_02_collect_supp_docs",
    "step_04_reconcile_tb"
