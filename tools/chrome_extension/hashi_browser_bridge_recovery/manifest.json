{
  "manifest_version": 3,
  "name": "HASHI Browser Bridge Recovery",
  "version": "0.1.0",
  "description": "Minimal recovery build for HASHI browser bridge.",
  "key": "",
  "background": {
    "service_worker": "service_worker.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "HASHI Browser Bridge Recovery"
  }
}
