{
  "manifest_version": 3,
  "name": "HASHI Browser Bridge",
  "version": "0.1.0",
  "description": "HASHI Option D browser bridge for real-profile automation via a trusted extension.",
  "key": "",
  "background": {
    "service_worker": "service_worker.js"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "nativeMessaging",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "HASHI Browser Bridge"
  }
}
