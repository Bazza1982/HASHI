HASHI_DEPLOYMENT_PROFILE=enterprise
HASHI_WORKBENCH_PORT=18800
HASHI_ORGANIZATION_ID=ORG-001

# Set secrets through your deployment secret manager in production.
# Do not commit real values.
HASHI_WORKBENCH_ADMIN_TOKEN=change-me

# Optional live audit export settings. Use a secret manager for real endpoints
# and authorization headers.
HASHI_AUDIT_EXPORT_ENDPOINT=https://siem.example.com/ingest
HASHI_AUDIT_EXPORT_FORMAT=siem
HASHI_AUDIT_EXPORT_HEADER=Authorization: Bearer change-me
HASHI_AUDIT_EXPORT_BATCH_SIZE=100
HASHI_AUDIT_EXPORT_TIMEOUT=10
HASHI_AUDIT_EXPORT_MAX_ATTEMPTS=3
HASHI_AUDIT_EXPORT_BACKOFF=1
