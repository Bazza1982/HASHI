{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hashi.dev/ete/v1/project.schema.json",
  "title": "ETE Project",
  "description": "Schema for project.json in an ETE bundle. Contains project-level metadata including name, status, ownership, and tags.",
  "type": "object",
  "required": ["project_id", "name", "status", "created_at", "updated_at"],
  "additionalProperties": true,
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Unique identifier for this project."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the project."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the project.",
      "default": ""
    },
    "status": {
      "type": "string",
      "description": "Current status of the project (e.g. 'active', 'completed', 'archived')."
    },
    "priority": {
      "type": "string",
      "description": "Priority level (e.g. 'high', 'medium', 'low')."
    },
    "owner": {
      "type": "string",
      "description": "Owner or responsible party for the project."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the project was created."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the project was last updated."
    },
    "tags": {
      "type": "array",
      "description": "Tags for categorizing the project.",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "extra": {
      "type": "object",
      "description": "System-specific metadata preserved but not interpreted by ETE.",
      "additionalProperties": true,
      "default": {}
    }
  }
}
