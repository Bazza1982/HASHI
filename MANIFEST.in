# Include documentation and metadata
include README.md
include LICENSE
include requirements.txt

# Include configuration examples
include *.json.example
include *.json.sample
include *.md

# Include onboarding language files
recursive-include onboarding/languages *.json
recursive-include onboarding/languages *.md

# Include agent seed prompts
recursive-include agent_seeds *.md

# Include skills
recursive-include skills *.md
recursive-include skills *.py
recursive-include skills *.sh

# Include documentation
recursive-include docs *.md
recursive-include doc *.md

# Include scripts
recursive-include scripts *.py
recursive-include scripts *.sh

# Exclude runtime and build artifacts
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.log
global-exclude *.lock
global-exclude *.pid
global-exclude .DS_Store
global-exclude *:Zone.Identifier

# Exclude workbench (Node.js project, separate package)
prune workbench

# Exclude runtime directories
prune logs
prune state
prune media
prune memory
prune workspaces
prune test_reports
prune .venv
prune .git
