#!/usr/bin/env bash
# Mock Codex CLI for testing

ACTION=""
PROMPT=""
OUTPUT_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --version) echo "codex-cli 0.114.0 (mock)"; exit 0 ;;
        exec|e) ACTION="exec"; shift ;;
        login) echo "Mock: Login successful (simulated)"; exit 0 ;;
        --json) shift ;;
        --ephemeral) shift ;;
        --skip-git-repo-check) shift ;;
        --dangerously-bypass-*) shift ;;
        --add-dir) shift 2 ;;
        --output-last-message) OUTPUT_FILE="$2"; shift 2 ;;
        --model) shift 2 ;;
        -c) shift 2 ;;
        --) shift; PROMPT="$*"; break ;;
        *) PROMPT="$PROMPT $1"; shift ;;
    esac
done

# Read from stdin if prompt is "-"
if [[ "$PROMPT" == "-" ]] || [[ -z "$PROMPT" ]]; then
    PROMPT=$(cat)
fi

sleep 0.3

# Output JSONL events like real Codex
echo '{"type":"turn.started","item":{"type":"thinking"}}'
sleep 0.1

echo '{"type":"item.completed","item":{"type":"agent_message","text":"Inspecting the workspace and planning the next step."}}'
sleep 0.1

echo '{"type":"item.started","item":{"type":"command_execution","command":["rg","--files"],"aggregated_output":"","exit_code":null,"status":"in_progress"}}'
sleep 0.1

echo '{"type":"item.completed","item":{"type":"command_execution","command":["rg","--files"],"aggregated_output":"README.md","exit_code":0,"status":"completed"}}'
sleep 0.1

RESPONSE="Mock Codex processed: ${PROMPT:0:100}..."

if [[ "$PROMPT" == *"error"* ]]; then
    echo '{"type":"error","message":"Simulated Codex error"}' >&2
    exit 1
fi

echo '{"type":"item.completed","item":{"type":"agent_message","text":"'"$RESPONSE"'"}}'
echo '{"type":"turn.completed","usage":{"input_tokens":10,"output_tokens":5}}'

# Write to output file if specified
if [[ -n "$OUTPUT_FILE" ]]; then
    echo "$RESPONSE" > "$OUTPUT_FILE"
fi

exit 0
